# Dream
import random
import time
def christmas_dream():
    print("You found yourself in Christmas night. You feel very warm, and a Santa Claus meet you and give you present!")
    time.sleep(2)
    presents = ("new socks!", "a Lego set!", "a cute crochet!", "a stuffed animal!", "a board game!", "a puzzle game!")
    christ = random.choice(presents)
    print("WOW! You have got", christ, "That's brilliant!")
