def christmas_dream():
    print("You found yourself in Christmas night. You feel very warm, and a Santa Claus meet you and give you present!")
    time.sleep(2)
    presents = ("new socks!", "a Lego set!", "a cute crochet!", "a stuffed animal!", "a board game!", "a puzzle game!")
    christ = random.choice(presents)
    print("WOW! You have got", christ, "That's brilliant!")
    time.sleep(2)
    print("Now, you've got present, so now let's decorate trees with everyone!")
    time.sleep(2)
    print("There are several things that we use to decorate Christmas tree. These are: string lights, candy canes, ornaments, "
          +"socks, wealth, the big star on top - the most important one, and fake presents (yes, fake, so do not open it :P ) under the tree.")
    orna = input("To help people, you need to type 'orna' five times! Let's go (e.g: pink, pink, pink)! ")
    time.sleep(2)
    if orna == "orna, orna, orna, orna, orna":
        print("Yuppi! You help people hang it on the tree!")
    else:
        print("Oh no, that is not correct!")
    time.sleep(2)
    string = input("Now let's wrap colorful string lights around the Christmas tree! Type 'color' 3 times (yell, yell, yell, yell)! ")
    time.sleep(2)
    if string == "color, color, color":
        print("Horray! You wrap it perfectly!")
    else:
        print("Oh no, that is not correct!")
    time.sleep(2)
    star = input("Then, slowly but surely, you help people decorate the tree. Now it looks beautiful! Wait... there is something missing..."
                 +"The star! The most sparkling, the most wonderful thing on the Christmas tree! "
                 +"Type 'star' one time, then our tree will finish! ")
    time.sleep(2)
    if star == "star":
        print("Wow! Everything looks beautiful! It lights all the night like a big torch! Everyone thank you, and give you more and more"
              +" presents... But... it's time to wake up!")
    else:
        print("Ohh, you cannot hang it on top of the tree, but you help a lot! The tree looks very pretty now! You want to enjoy"
              +" Christmas with your new friends, but... You wake up and see - now it is the summer...")
    time.sleep(2)
    exit()

    
